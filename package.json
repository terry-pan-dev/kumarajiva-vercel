{
  "name": "kumarajiva-vercel",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "remix vite:build",
    "dev": "dotenv -e .env -- remix vite:dev",
    "mastra:dev": "mastra dev --dir ./mastra",
    "mastra:build": "mastra build --dir ./mastra/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --no-error-on-unmatched-pattern --max-warnings=1 --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "db:push": "dotenv -e .env -- drizzle-kit push",
    "db:migrate": "dotenv -e .env -- drizzle-kit migrate",
    "db:check": "dotenv -e .env -- drizzle-kit check",
    "db:generate": "dotenv -e .env -- drizzle-kit generate",
    "db:studio": "dotenv -e .env -- drizzle-kit studio",
    "db:studio:prod": "dotenv -e .env.prod -- drizzle-kit studio",
    "get-hash-password": "tsx scripts/get-hash-password.ts",
    "db:seed": "tsx drizzle/seeds/dev/index.ts",
    "db:seed:prod": "dotenv -e .env.prod -- tsx drizzle/seeds/prod/index.ts",
    "db:migrate:data:01": "dotenv -e .env -- tsx drizzle/migrations/data/01-works-and-documents.ts",
    "db:migrate:data:02": "dotenv -e .env -- tsx drizzle/migrations/data/02-contributors.ts",
    "db:migrate:data:03": "dotenv -e .env -- tsx drizzle/migrations/data/03-projects.ts",
    "db:migrate:data:04": "dotenv -e .env -- tsx drizzle/migrations/data/04-sections.ts",
