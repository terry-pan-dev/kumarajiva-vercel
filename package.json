    "db:migrate:data:02:prod": "dotenv -e .env.prod -- tsx drizzle/migrations/data/02-contributors.ts",
    "db:migrate:data:03:prod": "dotenv -e .env.prod -- tsx drizzle/migrations/data/03-projects.ts",
    "db:migrate:data:04:prod": "dotenv -e .env.prod -- tsx drizzle/migrations/data/04-sections.ts",
    "read-glossary": "tsx scripts/read-glossary.ts",
    "read-paragraph": "tsx scripts/read-paragraph.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "transformation": "tsx scripts/transformation.ts",
    "prepare": "husky",
    "playwright:codegen": "playwright codegen http://localhost:3002",
    "playwright:test:headed": "playwright test --headed",
    "playwright:teardown": "playwright test global.teardown.ts"
